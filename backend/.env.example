# ─── Database ────────────────────────────────────────────────────────────────
# Local MongoDB (development)
MONGO_URL=mongodb://localhost:27017/resume_main
# Cloud MongoDB Atlas (production) — replace with your Atlas connection string
# MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/talentlens?retryWrites=true&w=majority

DB_NAME=Resume_Main

# ─── CORS ─────────────────────────────────────────────────────────────────────
# For development use '*', for production use your frontend domain
CORS_ORIGINS=*

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=TalentLens Solutions
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# ─── AI / API Keys ────────────────────────────────────────────────────────────
# GOOGLE_API_KEY=your-google-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key
